{
  "name": "tennis-schedular",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "serverless-http": "^3.2.0"
  },
  "scripts": {
    "install:all": "pnpm install",
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:server": "pnpm --filter tennis-schedular-server dev",
    "dev:client": "pnpm --filter tennis-schedular-client dev",
    "build": "pnpm --filter tennis-schedular-client run build",
    "start": "pnpm --filter tennis-schedular-server start",
    "migrate": "pnpm --filter tennis-schedular-server run migrate"
  }
}
